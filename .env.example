# ── Post for Me MCP Pro — environment ───────────────────────────────────────

# REQUIRED. Your Post for Me API key.
# Create one in the dashboard: https://app.postforme.dev  (Settings → API Keys)
POSTFORME_API_KEY=pfm_xxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL. Override the API base URL (self-hosted / open-source deployments).
# Default: https://api.postforme.dev
# POSTFORME_BASE_URL=https://api.postforme.dev

# OPTIONAL. Safety mode. When "true", every write tool (create/update/delete/
# publish/schedule) is blocked; only reads run. postforme_raw GET calls still work.
# POSTFORME_READONLY=false

# OPTIONAL. Disable the postforme_raw escape-hatch tool entirely.
# POSTFORME_DISABLE_RAW=false

# OPTIONAL. Per-request timeout in milliseconds (default 60000).
# POSTFORME_TIMEOUT_MS=60000

# OPTIONAL. Max automatic retries on 429 / 5xx / network errors (default 3).
# POSTFORME_MAX_RETRIES=3

# OPTIONAL (hardening). Restrict upload_media's local file reads to this
# directory. When set, file_path outside it is rejected (defense against using
# the tool to exfiltrate arbitrary host files). Leave unset to allow any path.
# POSTFORME_MEDIA_DIR=./media
